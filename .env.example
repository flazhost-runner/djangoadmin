DEBUG=True
SECRET_KEY=django-insecure-change-me
ALLOWED_HOSTS=localhost,127.0.0.1

# App
APP_PORT=3000
APP_NAME=DjangoAdmin
FE_TEMPLATE=agency-consulting-002-creative-agency

# Session
# SESSION_DRIVER: database | redis
# - database : simpan sesi di tabel DB (default, persist lintas restart)
# - redis    : simpan sesi di Redis cache (cepat, hilang saat Redis restart)
SESSION_DRIVER=database
SESSION_TTL_HOURS=6

# JWT
JWT_SECRET=jwt-secret-change-me
JWT_EXPIRES_IN=1h

# Password / OTP
BCRYPT_ROUNDS=10
OTP_EXPIRY_MINUTES=10

# Pagination
DEFAULT_PAGE_SIZE=10

# Database
DB_ENGINE=django.db.backends.mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=django_admin

# Storage (OSS / S3 compatible)
STORAGE_DRIVER=local
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_SSL=true

# Mail
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_NAME=DjangoAdmin
MAIL_FROM_ADDRESS=noreply@example.com

# Redis
REDIS_URL=redis://127.0.0.1:6379
